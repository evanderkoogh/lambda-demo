{
  "name": "frontend-demo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc --build && pnpm --filter @frontend-demo/infra typecheck",
    "dev": "bash scripts/start-local.sh",
    "test:api": "tsx --env-file=.env.local scripts/test-api.ts",
    "seed": "tsx scripts/seed-dynamo.ts",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
